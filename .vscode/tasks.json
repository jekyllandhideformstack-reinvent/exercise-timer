{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start dev server",
            "type": "shell",
            "command": "npx",
            "args": ["--yes", "serve", "-l", "8080", "."],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Accepting connections"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        }
    ]
}
